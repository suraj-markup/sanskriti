# Google Drive credentials for the /resources page.
#
# After copying this file to `.env`, fill in real values. Vite only exposes
# variables prefixed with VITE_ to the client bundle.
#
# Setup steps:
#   1. Create a Google Cloud project (one-time, free).
#   2. Enable the "Google Drive API" for that project.
#   3. Create an API key. Restrict it by HTTP referrer to your production
#      domain(s) and by API to "Google Drive API".
#   4. Create a Drive folder ("Study Material"). Share -> "Anyone with the
#      link can view". Copy the folder ID from the URL:
#      https://drive.google.com/drive/folders/<FOLDER_ID>
#
# When deploying to Vercel/Netlify, add these as Environment Variables in the
# hosting dashboard (do NOT commit the real `.env` file — it's gitignored).

VITE_GOOGLE_DRIVE_API_KEY=
VITE_GOOGLE_DRIVE_FOLDER_ID=
